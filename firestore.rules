rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================================================
    // FUNÇÕES AUXILIARES
    // ==================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Suporte a legado (Email) + Novo (UID)
    function isOwnerByEmail(email) {
      return request.auth.token.email == email;
    }

    function isMentor() {
      return request.auth.token.email == 'marcio.portes@me.com';
    }

    // ==================================================
    // REGRAS DE COLEÇÃO
    // ==================================================

    // MAIL
    match /mail/{mailId} {
      allow read: if isMentor();
      allow write: if false; 
    }

    // STUDENTS
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, delete: if isMentor();
      // Mentor pode tudo; aluno pode atualizar campos do seu próprio doc
      // DEC-024: onboardingStatus é do aluno (progressão no assessment)
      allow update: if isMentor() || (
        isOwner(studentId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['status', 'firstLoginAt', 'onboardingStatus']
        )
      );

      // PERFIL EMOCIONAL (subcollection) — Fase 1.4.0
      match /emotionalProfile/{docId} {
        allow read: if isAuthenticated() && (isMentor() || isOwner(studentId));
        allow write: if isMentor() || isOwner(studentId);
      }

      // REVISÃO SEMANAL (subcollection) — issue #102
      // A4: state machine DRAFT → CLOSED → ARCHIVED (terminal/imutável).
      // Aluno vê só CLOSED e ARCHIVED; mentor vê tudo.
      match /reviews/{reviewId} {
        allow read: if isMentor() || (
          isOwner(studentId) &&
          resource.data.status in ['CLOSED', 'ARCHIVED']
        );
        allow create: if isMentor() &&
          request.resource.data.status == 'DRAFT';
        allow update: if (
          // Mentor: transições de state machine (A4).
          (isMentor() && (
            (resource.data.status == 'DRAFT' && request.resource.data.status in ['DRAFT', 'CLOSED']) ||
            (resource.data.status == 'CLOSED' && request.resource.data.status in ['CLOSED', 'ARCHIVED']) ||
            (resource.data.status == 'ARCHIVED' && request.resource.data.status == 'ARCHIVED')
          )) ||
          // Stage 4.5: aluno toggla apenas alunoDoneIds em revisão CLOSED
          // (arrayUnion/arrayRemove). Campo separado do item.done (mentor).
          (isOwner(studentId) &&
            resource.data.status == 'CLOSED' &&
            request.resource.data.status == 'CLOSED' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['alunoDoneIds']))
        );
        allow delete: if isMentor() && resource.data.status != 'ARCHIVED';
      }
    }

    // MENTOR CONFIG (compliance rules) — Fase 1.3.2
    match /mentorConfig/{mentorId} {
      allow read: if isAuthenticated();
      allow write: if isMentor() && isOwner(mentorId);
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isMentor();
    }

    // TRADES — DEC-024: dados do aluno, aluno tem acesso total
    match /trades/{tradeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); 
      allow update, delete: if isAuthenticated() && (
        isMentor() || 
        isOwner(resource.data.studentId) || 
        isOwnerByEmail(resource.data.studentEmail)
      );

      // PARCIAIS (subcollection de trades)
      match /partials/{partialId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated();
      }
    }

    // ACCOUNTS — DEC-024: dados do aluno, aluno tem acesso total
    match /accounts/{accountId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.studentId) ||
        (resource.data.studentEmail != null && isOwnerByEmail(resource.data.studentEmail))
      );

      // DRAWDOWN HISTORY (subcollection) — Prop Firm Engine #52 Fase 2
      // Append-only audit log. Apenas CF (admin SDK) escreve. Aluno/mentor lêem.
      match /drawdownHistory/{historyId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // MOVEMENTS — DEC-024: dados do aluno, aluno tem acesso total
    match /movements/{movementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isMentor() || 
        (resource.data.createdBy == request.auth.uid) ||
        (resource.data.studentId == request.auth.uid) ||
        (resource.data.studentEmail != null && isOwnerByEmail(resource.data.studentEmail))
      );
    }

    // PLANS — DEC-025: dados do aluno, auth != null (fix #89)
    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ==================================================
    // CSV IMPORT — STAGING + TEMPLATES (v1.18.0, Issue #23)
    // ==================================================

    // CSV STAGING TRADES — DEC-024: dados do aluno, acesso total
    match /csvStagingTrades/{tradeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.studentId)
      );
    }

    // CSV TEMPLATES — templates de mapeamento CSV (compartilhados)
    match /csvTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.createdBy)
      );
    }

    // ==================================================
    // DADOS MESTRES
    // ==================================================

    match /currencies/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }
    match /brokers/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }
    match /tickers/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }
    match /exchanges/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }
    match /emotions/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }

    match /setups/{setupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isMentor() || (resource.data.createdBy == request.auth.uid && resource.data.isGlobal == false);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.targetUserId == request.auth.uid || 
        (resource.data.targetRole == 'mentor' && isMentor()) ||
        (resource.data.targetRole == 'student' && !isMentor())
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.targetUserId == request.auth.uid || isMentor());
      allow delete: if isMentor();
    }

    // ========== Order Import (CHUNK-10) ==========
    // Princípio: aluno é autoridade máxima sobre seus dados.
    // Qualquer usuário autenticado pode criar e ler.
    // Staging: aluno pode deletar (cleanup). Orders: imutáveis.

    match /ordersStagingArea/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      allow update: if false;
    }

    match /orders/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    match /orderAnalysis/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // ========== Prop Firm Templates (CHUNK-17, issue #052) ==========
    // Catálogo de templates de mesas proprietárias (collection raiz, INV-15 aprovado)
    // Mentor configura, todos autenticados podem ler (aluno seleciona ao criar conta PROP)
    match /propFirmTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isMentor();
    }

    // ========== Assessment — Student Onboarding (CHUNK-09) ==========
    // DEC-024: Aluno é autoridade sobre seus dados. auth != null.
    match /students/{studentId}/assessment/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /students/{studentId}/assessment/{docId}/{subcol}/{subId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ========== Subscriptions — Controle de Assinaturas (CHUNK-16, issue #094) ==========
    // DEC-055: Subcollection de students. DEC-056: type trial/paid + accessTier.
    // Regras para acesso direto via path students/{id}/subscriptions/{subId}
    match /students/{studentId}/subscriptions/{subscriptionId} {
      allow read: if isMentor();
      allow write: if isMentor();

      match /payments/{paymentId} {
        allow read: if isMentor();
        allow write: if isMentor();
      }
    }

    // collectionGroup('subscriptions') — permite queries cross-student do mentor
    match /{path=**}/subscriptions/{subscriptionId} {
      allow read: if isMentor();
    }
  }
}