rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================================================
    // FUNÇÕES AUXILIARES
    // ==================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Suporte a legado (Email) + Novo (UID)
    function isOwnerByEmail(email) {
      return request.auth.token.email == email;
    }

    function isMentor() {
      return request.auth.token.email == 'marcio.portes@me.com';
    }

    // Hard seal — issue #259 (1A). Bloqueia write em trade cuja date está em
    // algum cycle fechado do plano (sealedCycleRanges). Cache simples via
    // lastClosedCycleEnd (fronteira otimista — gateway client tem check rico).
    // Trade.date deve estar acima de lastClosedCycleEnd OU plano não tem ciclo selado.
    function isTradeDateNotSealed(planId, tradeDate) {
      let plan = get(/databases/$(database)/documents/plans/$(planId)).data;
      return !('lastClosedCycleEnd' in plan) ||
             plan.lastClosedCycleEnd == null ||
             tradeDate > plan.lastClosedCycleEnd;
    }

    // ==================================================
    // REGRAS DE COLEÇÃO
    // ==================================================

    // MAIL
    match /mail/{mailId} {
      allow read: if isMentor();
      allow write: if false; 
    }

    // STUDENTS
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, delete: if isMentor();
      // Mentor pode tudo; aluno pode atualizar campos do seu próprio doc
      // DEC-024: onboardingStatus é do aluno (progressão no assessment)
      // DEC-AUTO-271-01 (#271): accessStatus incluído — AuthContext.activateStudent
      // escreve {status, accessStatus, firstLoginAt} no 1º login do aluno.
      // Antes disto, regra rejeitava o update inteiro (allowlist hasOnly), nada era
      // gravado e badge "aguardando 1º login" persistia. Regressão de DEC-AUTO-263-07.
      allow update: if isMentor() || (
        isOwner(studentId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['status', 'firstLoginAt', 'onboardingStatus', 'accessStatus']
        )
      );

      // PERFIL EMOCIONAL (subcollection) — Fase 1.4.0
      match /emotionalProfile/{docId} {
        allow read: if isAuthenticated() && (isMentor() || isOwner(studentId));
        allow write: if isMentor() || isOwner(studentId);
      }

      // REVISÃO SEMANAL (subcollection) — issue #102
      // A4: state machine DRAFT → CLOSED → ARCHIVED (terminal/imutável).
      // Aluno vê só CLOSED e ARCHIVED; mentor vê tudo.
      match /reviews/{reviewId} {
        allow read: if isMentor() || (
          isOwner(studentId) &&
          resource.data.status in ['CLOSED', 'ARCHIVED']
        );
        allow create: if isMentor() &&
          request.resource.data.status == 'DRAFT';
        allow update: if (
          // Mentor: transições de state machine (A4).
          (isMentor() && (
            (resource.data.status == 'DRAFT' && request.resource.data.status in ['DRAFT', 'CLOSED']) ||
            (resource.data.status == 'CLOSED' && request.resource.data.status in ['CLOSED', 'ARCHIVED']) ||
            (resource.data.status == 'ARCHIVED' && request.resource.data.status == 'ARCHIVED')
          )) ||
          // Stage 4.5: aluno toggla apenas alunoDoneIds em revisão CLOSED
          // (arrayUnion/arrayRemove). Campo separado do item.done (mentor).
          (isOwner(studentId) &&
            resource.data.status == 'CLOSED' &&
            request.resource.data.status == 'CLOSED' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['alunoDoneIds']))
        );
        allow delete: if isMentor() && resource.data.status != 'ARCHIVED';
      }
    }

    // MENTOR CONFIG (compliance rules) — Fase 1.3.2
    match /mentorConfig/{mentorId} {
      allow read: if isAuthenticated();
      allow write: if isMentor() && isOwner(mentorId);
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isMentor();
    }

    // TRADES — DEC-024: dados do aluno, aluno tem acesso total
    // DEC-AUTO-188-01/02: lock comportamental — quando _lockedByMentor == true, os
    // 3 campos whitelisted (emotionEntry/emotionExit/setup) ficam imutáveis via rule.
    // Metadados de lock/auditoria (_lockedByMentor, _lockedAt, _lockedBy, _mentorEdits,
    // _studentOriginal, _unlockedAt, _unlockedBy) só podem ser escritos por mentor
    // ou CF (admin SDK bypassa rules).
    match /trades/{tradeId} {
      allow read: if isAuthenticated();
      // Hard seal #259 — bloqueia create se date está em ciclo fechado do plano.
      // #269 — trade nasce NONE ou DRAFT (nunca DISCUSSED, que só vem de publish via admin SDK).
      allow create: if isAuthenticated() &&
        isTradeDateNotSealed(request.resource.data.planId, request.resource.data.date) &&
        (request.resource.data.get('reviewState', 'NONE') in ['NONE', 'DRAFT']);
      allow update: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.studentId) ||
        isOwnerByEmail(resource.data.studentEmail)
      ) && (
        // FIX: usar .get() com default — `resource.data._lockedByMentor` quando o
        // campo NÃO existe no doc causa runtime error → permission-denied (bug
        // descoberto em 22/05/2026 via bisseção da rule). Trades nunca tocados
        // pelo mentor não têm o campo, então acesso direto quebra.
        resource.data.get('_lockedByMentor', false) != true ||
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['emotionEntry', 'emotionExit', 'setup'])
      ) && (
        isMentor() ||
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          '_lockedByMentor', '_lockedAt', '_lockedBy',
          '_unlockedAt', '_unlockedBy',
          '_mentorEdits', '_studentOriginal',
          // Issue #219 — classificação mentor (técnico/sorte). Aluno read-only.
          'mentorClassification', 'mentorClassificationFlags',
          'mentorClassificationReason', 'mentorClassifiedAt', 'mentorClassifiedBy',
          // Issue #221 — limpeza de violação (compliance + emocional). Aluno read-only.
          'mentorClearedViolations'
        ])
      ) && (
        // Hard seal #259 — bloqueia update se date está em ciclo fechado.
        isTradeDateNotSealed(resource.data.planId, resource.data.date) ||
        // Exceção #302 — metadados de revisão do mentor são isentos do seal:
        // mentor revisa/classifica trade em qualquer estado de ciclo (decisão de
        // produto 01/06/2026). Quando o ÚNICO delta é metadado mentor-only, dispensa
        // o seal e NÃO chama get() — resolve também plano órfão (get().data quebra).
        // Bug original: bulk feedback (writeBatch atômico) caía se 1 trade do lote
        // estava em ciclo selado. Allowlist espelha o bloco aluno-readonly acima.
        (
          isMentor() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'mentorFeedback', 'feedbackDate', 'feedbackHistory', 'status', 'updatedAt',
            'mentorClassification', 'mentorClassificationFlags',
            'mentorClassificationReason', 'mentorClassifiedAt', 'mentorClassifiedBy',
            'mentorClearedViolations'
          ])
        ) ||
        // Exceção #308 — auto-revisão do aluno é reflexão (metadado), isenta do seal
        // #259 quando o ÚNICO delta é selfReview (mesma lógica de metadado do #302).
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['selfReview', 'updatedAt'])
      ) && (
        // #308 — auto-revisão imutável depois que o trade é discutido em revisão
        // (reviewState=DISCUSSED, #269). Vale para todos. get() com default p/ docs sem o campo.
        resource.data.get('reviewState', 'NONE') != 'DISCUSSED' ||
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['selfReview'])
      ) && (
        // #269 — transições de reviewState/draftReviewId são EXCLUSIVAS das callables
        // (createReviewDraft/publishReview/deleteReviewDraft via admin SDK, que bypassa rules).
        // Nenhum cliente (aluno OU mentor) altera esses campos por update direto.
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reviewState', 'draftReviewId'])
      );
      allow delete: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.studentId) ||
        isOwnerByEmail(resource.data.studentEmail)
      ) &&
      // Hard seal #259 — bloqueia delete se date está em ciclo fechado.
      isTradeDateNotSealed(resource.data.planId, resource.data.date);

      // PARCIAIS (subcollection de trades)
      match /partials/{partialId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated();
      }
    }

    // ACCOUNTS — DEC-024: dados do aluno, aluno tem acesso total
    match /accounts/{accountId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.studentId) ||
        (resource.data.studentEmail != null && isOwnerByEmail(resource.data.studentEmail))
      );

      // DRAWDOWN HISTORY (subcollection) — Prop Firm Engine #52 Fase 2
      // Append-only audit log. Apenas CF (admin SDK) escreve. Aluno/mentor lêem.
      match /drawdownHistory/{historyId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // MOVEMENTS — DEC-024: dados do aluno, aluno tem acesso total
    match /movements/{movementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isMentor() || 
        (resource.data.createdBy == request.auth.uid) ||
        (resource.data.studentId == request.auth.uid) ||
        (resource.data.studentEmail != null && isOwnerByEmail(resource.data.studentEmail))
      );
    }

    // PLANS — DEC-025: dados do aluno, auth != null (fix #89)
    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // #269 (D7) — `activeDraftReviewId` é ponteiro mantido EXCLUSIVAMENTE pelas
      // callables (createReviewDraft/publishReview/deleteReviewDraft via admin SDK,
      // que bypassa rules). Nenhum cliente o altera por update direto; tradeGateway
      // apenas lê. Mantém o demais update aberto (posição pré-existente do plano).
      allow update: if isAuthenticated() &&
        request.resource.data.get('activeDraftReviewId', null) == resource.data.get('activeDraftReviewId', null);
      allow delete: if isAuthenticated();
    }

    // CYCLE CLOSURES — Issue #259 (1A — Ritual completo de Fechamento de Ciclo)
    // Documento imutável escrito pela CF closeCycle (admin SDK bypassa rules).
    // Read: aluno dono (resource.data.studentId == auth.uid) OU mentor.
    // Write: false — toda mutação é via CF (closeCycle, reopenCycle).
    match /cycleClosures/{closureId} {
      allow read: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.studentId)
      );
      allow write: if false;
    }

    // ==================================================
    // CSV IMPORT — STAGING + TEMPLATES (v1.18.0, Issue #23)
    // ==================================================

    // CSV STAGING TRADES — DEC-024: dados do aluno, acesso total
    match /csvStagingTrades/{tradeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.studentId)
      );
    }

    // CSV TEMPLATES — templates de mapeamento CSV (compartilhados)
    match /csvTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        isMentor() ||
        isOwner(resource.data.createdBy)
      );
    }

    // ==================================================
    // DADOS MESTRES
    // ==================================================

    match /currencies/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }
    match /brokers/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }
    match /tickers/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }
    match /exchanges/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }
    match /emotions/{id=**} { allow read: if isAuthenticated(); allow write: if isMentor(); }

    match /setups/{setupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isMentor() || (resource.data.createdBy == request.auth.uid && resource.data.isGlobal == false);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.targetUserId == request.auth.uid || 
        (resource.data.targetRole == 'mentor' && isMentor()) ||
        (resource.data.targetRole == 'student' && !isMentor())
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.targetUserId == request.auth.uid || isMentor());
      allow delete: if isMentor();
    }

    // ========== Order Import (CHUNK-10) ==========
    // Princípio: aluno é autoridade máxima sobre seus dados.
    // Qualquer usuário autenticado pode criar e ler.
    // Staging: aluno pode deletar (cleanup). Orders: imutáveis.

    match /ordersStagingArea/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      allow update: if false;
    }

    match /orders/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    match /orderAnalysis/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // ========== Prop Firm Templates (CHUNK-17, issue #052) ==========
    // Catálogo de templates de mesas proprietárias (collection raiz, INV-15 aprovado)
    // Mentor configura, todos autenticados podem ler (aluno seleciona ao criar conta PROP)
    match /propFirmTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isMentor();
    }

    // ========== Assessment — Student Onboarding (CHUNK-09) ==========
    // DEC-024: Aluno é autoridade sobre seus dados. auth != null.
    match /students/{studentId}/assessment/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /students/{studentId}/assessment/{docId}/{subcol}/{subId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ========== Subscriptions — Controle de Assinaturas (CHUNK-16, issue #094) ==========
    // DEC-055: Subcollection de students. DEC-056: type trial/paid + accessTier.
    // Regras para acesso direto via path students/{id}/subscriptions/{subId}
    match /students/{studentId}/subscriptions/{subscriptionId} {
      allow read: if isMentor();
      allow write: if isMentor();

      match /payments/{paymentId} {
        allow read: if isMentor();
        allow write: if isMentor();
      }
    }

    // collectionGroup('subscriptions') — permite queries cross-student do mentor
    match /{path=**}/subscriptions/{subscriptionId} {
      allow read: if isMentor();
    }

    // collectionGroup('payments') — read-only do mentor (escrita só via path direto, issue #254)
    match /{path=**}/payments/{paymentId} {
      allow read: if isMentor();
    }

    // ========== Maturity Engine — Progressão 4D × 5 stages (CHUNK-09, issue #119) ==========
    // INV-15 aprovada. Subcollection /maturity/{current|history/{YYYY-MM-DD}}.
    // Aluno lê próprio, mentor lê alunos dele. Apenas CF (admin SDK) escreve.
    match /students/{studentId}/maturity/{docId=**} {
      allow read: if isAuthenticated() && (isOwner(studentId) || isMentor());
      allow write: if false;
    }

    // collectionGroup('maturity') — useMentorMaturityOverview faz query cross-student
    // pra pintar o semáforo de maturidade na MentorDashboard. Sem essa regra de
    // collection group a query é default-deny mesmo pro mentor.
    match /{path=**}/maturity/{docId} {
      allow read: if isMentor();
    }

    // ========== Selic Cache — Risk-free rate diária BCB SGS-11 (CHUNK-09, issue #235) ==========
    // INV-15 aprovada — comment #issuecomment-4364111738.
    // Doc raiz + subcollection history/<YYYY-MM-DD>. Apenas CF/Admin SDK escreve
    // (fetchSelicDaily diária + bootstrap run-once). Qualquer usuário autenticado lê
    // (consumido pelo helper getSelicForDate em UI e CFs).
    match /systemConfig/selic {
      allow read: if isAuthenticated();
      allow write: if false;

      match /history/{dateId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }
  }
}